//@version=6
library("Codex/LogisticRegressionUtils/1", overlay=false)

// Basic logistic function used by the model
export logistic(x1, x2, w0, w1, w2) =>
    exponent = math.exp(-(w0 + w1 * x1 + w2 * x2))
    1.0 / (1.0 + exponent)

// Logistic regression loss utility
export logLoss(y, p) =>
    -y * math.log(p) - (1 - y) * math.log(1 - p)
